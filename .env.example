# ──────────────────────────────────────────────
# ELK Stack – environment variables
# Copy this to .env and adjust before running.
# ──────────────────────────────────────────────

# Elastic superuser password (used by Elasticsearch, Logstash, Filebeat)
ELASTIC_PASSWORD=changeme

# Password for the kibana_system built-in user
# Run setup.sh first – it creates this user automatically.
KIBANA_PASSWORD=changeme

# Must be at least 32 characters (used for Kibana saved-object encryption)
KIBANA_ENCRYPTION_KEY=supersecretkey32charslong!!!!!

# JVM heap sizes  (keep Xms == Xmx, max ~50 % of host RAM)
ES_HEAP=512m
LS_HEAP=256m
